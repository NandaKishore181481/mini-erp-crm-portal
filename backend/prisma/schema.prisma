generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SALES
  WAREHOUSE
  ACCOUNTS
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  notes        FollowUpNote[]
  movements    StockMovement[]
  challans     Challan[]
}

enum CustomerType {
  RETAIL
  WHOLESALE
  DISTRIBUTOR
}

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
}

model Customer {
  id           String         @id @default(uuid())
  name         String
  mobile       String
  email        String
  businessName String
  gstNumber    String?
  type         CustomerType
  address      String
  status       CustomerStatus
  followUpDate DateTime?
  createdAt    DateTime       @default(now())

  notes        FollowUpNote[]
  challans     Challan[]
}

model FollowUpNote {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  note       String
  createdBy  String
  user       User     @relation(fields: [createdBy], references: [id])
  createdAt  DateTime @default(now())
}

model Product {
  id            String   @id @default(uuid())
  name          String
  sku           String   @unique
  category      String
  unitPrice     Float
  stock         Int
  minStockAlert Int
  location      String
  createdAt     DateTime @default(now())

  movements     StockMovement[]
  challanItems  ChallanItem[]
}

enum MovementType {
  IN
  OUT
}

model StockMovement {
  id         String       @id @default(uuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id])
  qtyChanged Int
  type       MovementType
  reason     String
  createdBy  String
  user       User         @relation(fields: [createdBy], references: [id])
  createdAt  DateTime     @default(now())
}

enum ChallanStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model Challan {
  id            String        @id @default(uuid())
  challanNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  status        ChallanStatus @default(DRAFT)
  totalQty      Int
  createdBy     String
  user          User          @relation(fields: [createdBy], references: [id])
  createdAt     DateTime      @default(now())

  items         ChallanItem[]
}

model ChallanItem {
  id                  String   @id @default(uuid())
  challanId           String
  challan             Challan  @relation(fields: [challanId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  productNameSnapshot String
  skuSnapshot         String
  priceSnapshot       Float
  qty                 Int
}
